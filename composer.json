{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "your-vendor/tall-modules-starter",
    "type": "project",
    "description": "A TALL-stack starter (Laravel, Filament, Livewire, Alpine, Tailwind v4) with nwidart/laravel-modules.",
    "keywords": ["laravel", "filament", "livewire", "tailwindcss", "tall-stack", "starter"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "filament/filament": "^3.0",
        "laravel/framework": "^12.0",
        "laravel/tinker": "^2.10",
        "nwidart/laravel-modules": "^11.0",
        "symfony/clock": "^7.0",
        "symfony/css-selector": "^7.0",
        "symfony/event-dispatcher": "^7.0",
        "symfony/string": "^7.0",
        "symfony/translation": "^7.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.2",
        "laravel/pint": "^1.0",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.1",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "pestphp/pest-plugin-livewire": "^3.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Modules\\Website\\": "Modules/Website/app/",
            "Modules\\Website\\Database\\Factories\\": "Modules/Website/database/factories/",
            "Modules\\Website\\Database\\Seeders\\": "Modules/Website/database/seeders/",
            "Modules\\Registration\\": "Modules/Registration/app/",
            "Modules\\Registration\\Database\\Factories\\": "Modules/Registration/database/factories/",
            "Modules\\Registration\\Database\\Seeders\\": "Modules/Registration/database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "Modules\\Website\\Tests\\": "Modules/Website/tests/",
            "Modules\\Registration\\Tests\\": "Modules/Registration/tests/"
        }
    },
    "scripts": {
        "setup": [
            "composer install",
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\"",
            "@php artisan key:generate",
            "@php artisan migrate --force",
            "npm install --ignore-scripts",
            "npm run build"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1 --timeout=0\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite --kill-others"
        ],
        "test": [
            "@php artisan config:clear --ansi @no_additional_args",
            "@php artisan test"
        ],
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "platform": {
            "php": "8.3.6"
        },
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true,
            "wikimedia/composer-merge-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
